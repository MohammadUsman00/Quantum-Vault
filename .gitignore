# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
 
# rust/anchor
/target/

# misc
.DS_Store
*.pem
*.key
*.p12
*.secret
*id_rsa*
*id_ed25519*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
