{
  "version": "0.1.0",
  "name": "quantum_vault",
  "instructions": [
    {
      "name": "initializeVault",
      "accounts": [
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "pqPubkeyHash",
          "type": {
            "array": ["u8", 32]
          }
        }
      ]
    },
    {
      "name": "depositSol",
      "accounts": [
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "amount",
          "type": "u64"
        }
      ]
    },
    {
      "name": "withdrawSol",
      "accounts": [
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "amount",
          "type": "u64"
        }
      ]
    }
  ],
  "accounts": [
    {
      "name": "VaultAccount",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "owner",
            "type": "publicKey"
          },
          {
            "name": "pqPubkeyHash",
            "type": {
              "array": ["u8", 32]
            }
          },
          {
            "name": "isProtected",
            "type": "bool"
          },
          {
            "name": "solDeposited",
            "type": "u64"
          },
          {
            "name": "createdAt",
            "type": "i64"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "VaultInitialized",
      "fields": [
        { "name": "owner", "type": "publicKey", "index": false },
        { "name": "pqPubkeyHash", "type": { "array": ["u8", 32] }, "index": false },
        { "name": "createdAt", "type": "i64", "index": false }
      ]
    },
    {
      "name": "SolDeposited",
      "fields": [
        { "name": "owner", "type": "publicKey", "index": false },
        { "name": "amount", "type": "u64", "index": false },
        { "name": "total", "type": "u64", "index": false }
      ]
    },
    {
      "name": "SolWithdrawn",
      "fields": [
        { "name": "owner", "type": "publicKey", "index": false },
        { "name": "amount", "type": "u64", "index": false },
        { "name": "remaining", "type": "u64", "index": false }
      ]
    }
  ],
  "errors": [
    {
      "code": 6000,
      "name": "ZeroAmount",
      "msg": "Amount must be greater than zero"
    },
    {
      "code": 6001,
      "name": "InsufficientFunds",
      "msg": "Insufficient funds for this operation"
    },
    {
      "code": 6002,
      "name": "Overflow",
      "msg": "Arithmetic overflow"
    }
  ],
  "metadata": {
    "address": "6tLhtJ5vr4R2KF4xoDodQmuWKvGPm1orXRqvtTNy5P3t"
  }
}
